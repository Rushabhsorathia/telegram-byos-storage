APP_NAME="Telegram Storage"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Default to sqlite for easy local dev. Switch DB_CONNECTION=mysql for production.
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=telegram_storage
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Telegram Bot API endpoint. The public api.telegram.org caps uploads at 50 MB.
# For the 1.7 GB chunk size below, run a local Bot API server (uploads up to ~2 GB):
# docker run -p 8081:8080 -e TELEGRAM_API_ID=... -e TELEGRAM_API_HASH=... aiogram/telegram-bot-api:latest
TELEGRAM_BOT_API_BASE_URL="https://api.telegram.org"
# Max size of a single Telegram document. Files at/below this are NOT split;
# larger files are divided into equal parts each <= this size. 1740 MB ≈ 1.7 GB.
TELEGRAM_CHUNK_SIZE_MB=1740
TELEGRAM_UPLOAD_CONCURRENCY=3
# Generous HTTP timeouts so large (multi-hundred-MB / GB) chunk transfers to/from
# the Bot API don't get cut off mid-upload. Keep <= the job/worker timeouts.
TELEGRAM_REQUEST_TIMEOUT=1800
TELEGRAM_DOWNLOAD_TIMEOUT=1800

# Upload pipeline
UPLOAD_TEMP_DISK=local
UPLOAD_BROWSER_CHUNK_MB=8

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_API_URL="http://localhost:8000"
